# LLM Provider: "groq" (default, free) or "openai"
LLM_PROVIDER=groq

# Groq (free, fast — get key at https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (optional, only if LLM_PROVIDER=openai)
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4.1-nano

# Database (defaults to local SQLite if not set)
# DATABASE_URL=sqlite+aiosqlite:///app/data/mindmate.db

# ChromaDB vector store path (defaults to app/data/chroma)
# CHROMA_PATH=app/data/chroma

# Frontend URL for CORS (defaults to http://localhost:3000)
# CORS_ORIGINS=http://localhost:3000

# Langfuse observability (optional)
# LANGFUSE_PUBLIC_KEY=pk-lf-your-key
# LANGFUSE_SECRET_KEY=sk-lf-your-key
# LANGFUSE_HOST=https://cloud.langfuse.com
